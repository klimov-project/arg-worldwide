{
    "buildCommand": "cd frontend && npm install && npm run build && cd ../backend && npm install && npm run build",
    "devCommand": "cd frontend && npm install && npm run dev",
    "experimentalServices": {
        "frontend": {
            "entrypoint": "frontend",
            "routePrefix": "/",
            "framework": "nuxtjs"
        },
        "backend": {
            "entrypoint": "backend",
            "routePrefix": "/api"
        }
    },
    "env": {
        "NODE_ENV": "production",
        "FRONTEND_URL": "https://arg-worldwide.vercel.app"
    }
}